# Database (required for NextAuth + Prisma-backed API routes)
DATABASE_URL=postgresql://USER@localhost:5432/glimmora_dev

# NextAuth
AUTH_SECRET=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Audit
AUDIT_SIGNING_KEY_V1=

# Optional upstream Glimmora API
GLIMMORA_API_URL=
NEXT_PUBLIC_GLIMMORA_API_URL=

# Standalone backend service (proxied routes — optional until backend team ships)
BACKEND_SERVICE_URL=http://localhost:4000

# Email / SMTP — Gmail (use an App Password, not your regular password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=GlimmoraTeam <your-email@gmail.com>

# Razorpay (required for payment checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay X — source account number for contributor payouts (Settings → Account → Account Number)
RAZORPAY_X_ACCOUNT_NUMBER=

# Platform admin — Phase gate. Unset/0 = Phase-1 lean console (Dashboard,
# Tenants, Commercial gate, Mentors, Rubric Templates, KYC, Audit, Roles,
# Settings) + 3 personas. Set to 1 to restore the full Phase-2 surface.
NEXT_PUBLIC_ADMIN_PHASE2_ENABLED=0
