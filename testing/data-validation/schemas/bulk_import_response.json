{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bulk Import Response",
  "type": "object",
  "required": ["id", "file_name", "status", "total_rows"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "file_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["preview", "processing", "completed", "failed"]
    },
    "total_rows": {
      "type": "integer",
      "minimum": 0
    },
    "valid_rows": {
      "type": "integer",
      "minimum": 0
    },
    "invalid_rows": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
