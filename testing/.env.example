# Environment Variables Template for Testing

# ═══════════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════════
GLIMMORA_API_URL=http://localhost:9000
NEXT_PUBLIC_GLIMMORA_API_URL=http://localhost:9000
API_VERSION=v1
API_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════
# PostgreSQL (Neon Cloud)
DATABASE_URL=postgresql://glimmora:glimmora_dev@localhost:5432/glimmora_dev

# MongoDB (Atlas Cloud)
MONGODB_URI=mongodb+srv://test_user:test_password@cluster.mongodb.net/glimmora_test

# ═══════════════════════════════════════════════════════════════
# Cache & Session
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════
# Authentication & Tokens
# ═══════════════════════════════════════════════════════════════
AUTH_SECRET=test-secret-key-min-32-chars-long-required
JWT_SECRET=jwt-secret-key-min-32-chars-long-required
JWT_EXPIRY=3600

# ═══════════════════════════════════════════════════════════════
# Email Configuration (Testing/Mock)
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASS=test
SMTP_FROM=noreply@glimmora.test

# ═══════════════════════════════════════════════════════════════
# File Storage
# ═══════════════════════════════════════════════════════════════
BLOB_STORE_URL=http://localhost:3004
BLOB_STORE_API_KEY=test_api_key

# ═══════════════════════════════════════════════════════════════
# Event Streaming (Kafka)
# ═══════════════════════════════════════════════════════════════
KAFKA_BROKERS=localhost:29092
KAFKA_GROUP_ID=test_group
KAFKA_TOPIC_PREFIX=test_

# ═══════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
VERBOSE_LOGGING=false
DEBUG_MODE=false

# ═══════════════════════════════════════════════════════════════
# Testing Configuration
# ═══════════════════════════════════════════════════════════════
TEST_ENV=local
TEST_TIMEOUT=30
SKIP_EXTERNAL_SERVICES=false

# ═══════════════════════════════════════════════════════════════
# Feature Flags (Testing)
# ═══════════════════════════════════════════════════════════════
FEATURE_BULK_IMPORT=true
FEATURE_OAUTH=true
FEATURE_MFA=true
FEATURE_ADVANCED_SOW=true

# ═══════════════════════════════════════════════════════════════
# External Services (Mocked for Testing)
# ═══════════════════════════════════════════════════════════════
STRIPE_API_KEY=sk_test_fake_key
MICROSOFT_CLIENT_ID=test_client_id
MICROSOFT_CLIENT_SECRET=test_client_secret
SENDGRID_API_KEY=test_sendgrid_key

# ═══════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════
NODE_ENV=test
ENVIRONMENT=test
DEPLOYMENT_ENV=local

# ═══════════════════════════════════════════════════════════════
# Rate Limiting & Security
# ═══════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=false
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ═══════════════════════════════════════════════════════════════
# Browser Testing (E2E)
# ═══════════════════════════════════════════════════════════════
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_WORKERS=4
