# reviewer backend — copy to .env and fill in real values. DO NOT commit .env.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
REDIS_URL=redis://default:PASSWORD@HOST:PORT
API_SECRET_KEY=change-me-shared-jwt-secret
EMAIL_ENABLED=true
KAFKA_ENABLED=
PORT=
# Email / SMTP — Office365 (requires STARTTLS on port 587)
EMAIL_USER=you@example.com
EMAIL_APP_PASSWORD=your-smtp-app-password
EMAIL_FROM=Your Name <you@example.com>
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true
# Razorpay (TEST mode) — leave blank to keep payouts simulated
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Public frontend base URL used to build email links (login / reset / actions)
FRONTEND_BASE_URL=https://frontend-two-beta-64.vercel.app
