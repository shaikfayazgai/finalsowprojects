{
  "name": "glimmora-team",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "postinstall": "npm run db:generate -w frontend",
    "dev": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w frontend",
    "lint": "npm run lint -w frontend",
    "db:generate": "npm run db:generate -w frontend",
    "db:migrate": "npm run db:migrate -w frontend",
    "db:seed:local": "npm run db:seed:local -w frontend",
    "ensure:admin": "tsx --tsconfig frontend/tsconfig.json frontend/scripts/ensure-admin.ts",
    "ensure:enterprise": "tsx --tsconfig frontend/tsconfig.json frontend/scripts/ensure-enterprise.ts",
    "ensure:contributor": "tsx --tsconfig frontend/tsconfig.json frontend/scripts/ensure-contributor.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
