{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP requests / sec by service",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(glimmora_http_requests_total[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(glimmora_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "stat",
      "title": "5xx errors (5m)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(increase(glimmora_http_requests_total{status=~\"5..\"}[5m]))" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["glimmora"],
  "title": "Glimmora Platform Overview",
  "uid": "glimmora-overview",
  "version": 1
