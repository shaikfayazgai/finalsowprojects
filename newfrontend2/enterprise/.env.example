# Database (required for NextAuth + Prisma-backed API routes)
DATABASE_URL=postgresql://USER@localhost:5432/glimmora_dev

# NextAuth
AUTH_SECRET=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Audit
AUDIT_SIGNING_KEY_V1=

# Optional upstream Glimmora API
GLIMMORA_API_URL=
NEXT_PUBLIC_GLIMMORA_API_URL=

# Standalone backend service (proxied routes — optional until backend team ships)
BACKEND_SERVICE_URL=http://localhost:4000

# Platform admin — Phase gate. Unset/0 = Phase-1 lean console (Dashboard,
# Tenants, Commercial gate, Mentors, Rubric Templates, KYC, Audit, Roles,
# Settings) + 3 personas. Set to 1 to restore the full Phase-2 surface.
NEXT_PUBLIC_ADMIN_PHASE2_ENABLED=0
