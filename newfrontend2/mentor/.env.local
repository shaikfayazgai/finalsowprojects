# Local integration: point the Next proxies at the bundled MENTOR backend (:8101).
# The mentor FastAPI service (backend/app.py) runs on 8101 and shares the same
# Neon DB + API_SECRET_KEY, so login JWTs and OTP forgot-password verify both ways.
BACKEND_SERVICE_URL=http://127.0.0.1:8101
GLIMMORA_API_BASE_URL=http://127.0.0.1:8101
NEXT_PUBLIC_GLIMMORA_API_URL=http://127.0.0.1:8101
# AUTH_SECRET must equal the backend API_SECRET_KEY so JWTs verify both ways
AUTH_SECRET=8f3d9b2c1a7e64f05d8c93b1e6a47f29c0b5d83e1f9a627c4d0e8b3a5f719c2d6
NEXTAUTH_SECRET=8f3d9b2c1a7e64f05d8c93b1e6a47f29c0b5d83e1f9a627c4d0e8b3a5f719c2d6
