generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Multi-tenant root entity.
///
/// Every enterprise customer of Glimmora is a Tenant. Tenant-scoped tables
/// carry a `tenantId` FK; later migrations add Postgres RLS policies that
/// enforce isolation at the DB level.
///
/// Cross-tenant entities (contributors, mentors, skill taxonomy, rubric
/// templates) do not carry a tenantId — they're shared across tenants by
/// design.
///
/// Lifecycle: provisioning → active → paused → closed. See platform admin
/// portal spec §5.C and §7.1.
model Tenant {
  id String @id @default(uuid())

  /// URL slug (e.g. "acme-corp"). Used for tenant resolution from headers
  /// or cookies. Unique across the platform.
  slug String @unique

  /// Display name (e.g. "Acme Corp").
  name String

  /// Primary email domain. Used for SSO routing — a user signing in with
  /// @acme.com is mapped to this tenant's IdP. Unique when set.
  domain String? @unique

  /// Whether `domain` has been verified (DNS check or admin confirmation).
  domainVerified Boolean @default(false)

  /// Subscription tier: "trial" | "pilot" | "growth" | "enterprise". Drives
  /// feature flags + commercial terms.
  subscriptionTier String @default("pilot")

  /// When the current subscription period started (plan assignment / upgrade).
  subscriptionStartedAt DateTime?

  /// Trial expiry — set when subscriptionTier is "trial".
  trialEndsAt DateTime?

  /// Usage counters for plan limits. Shape: { activeSows, activeProjects,
  /// seats, aiInvocationsMonth, aiInvocationsPeriod }.
  usageCounters Json?

  /// Lifecycle status: "provisioning" | "active" | "paused" | "closed".
  /// "paused" blocks all user logins for this tenant.
  status String @default("provisioning")

  /// Default region for resources created under this tenant. ISO 3166-1
  /// alpha-2 (e.g., "IN", "US").
  region String @default("IN")

  /// Default currency for billing + payouts. ISO 4217 (e.g., "INR", "USD").
  currency String @default("INR")

  /// Default IANA timezone (e.g., "Asia/Kolkata").
  timezone String @default("Asia/Kolkata")

  /// Master Services Agreement reference (legal contract identifier).
  contractRef String?

  /// Lifecycle timestamps — set when status transitions occur.
  provisionedAt DateTime?
  pausedAt      DateTime?
  closedAt      DateTime?

  /// Per-tenant SSO (SAML 2.0 or OIDC) configuration.
  ///
  /// Shape (TypeScript):
  ///   {
  ///     enabled: boolean,
  ///     kind: 'saml' | 'oidc',
  ///     saml?: {
  ///       entityId: string,
  ///       ssoUrl: string,
  ///       certificate: string,   // PEM-format IdP signing certificate
  ///       attributeMap: { email: string, firstName?: string, lastName?: string }
  ///     },
  ///     oidc?: {
  ///       issuer: string,
  ///       clientId: string,
  ///       clientSecret: string,
  ///       scopes?: string[]
  ///     }
  ///   }
  ///
  /// Null until tenant admin (or plat.admin) configures SSO. The login
  /// UI uses /api/auth/sso/discover?tenantSlug=… to determine where to
  /// redirect users. JIT-provisioned users on first SSO sign-in are
  /// stamped with provider = 'saml-<slug>' or 'oidc-<slug>' for audit.
  ssoConfig Json?

  /// Per-tenant rate-card configuration. Shape:
  ///   {
  ///     currency: 'INR' | 'USD' | ...,
  ///     default: number,  // per-hour rate in the main unit (₹1200)
  ///     bySegment?: {
  ///       student?: number,
  ///       women_workforce?: number,
  ///       general_workforce?: number,
  ///       internal?: number,
  ///     }
  ///   }
  ///
  /// Null until configured; payout computation falls back to the
  /// PHASE1_DEFAULT_RATE_PER_HOUR_INR platform default. The rate that
  /// applies to a task is snapshotted into TaskDefinition.agreedRatePerHour
  /// at assignment time so subsequent rate-card edits don't retroactively
  /// alter payouts.
  rateCards Json?

  /// Per-tenant data retention overrides (spec doc 02 §5.I.3). Shape:
  ///   {
  ///     audit_event:          { mode: 'indefinite' | 'days', days?: number },
  ///     task_evidence:        { mode: 'indefinite' | 'days', days?: number },
  ///     submission_withdrawn: { mode: 'days', days: number },
  ///     mentor_notes:         { mode: 'indefinite' | 'days', days?: number },
  ///     kyc_records:          { mode: 'indefinite' | 'days', days?: number },
  ///   }
  ///
  /// Each entity has a platform-enforced minimum floor; tenants may
  /// extend retention (or keep indefinite) but never reduce below the
  /// floor (PUT enforces this server-side). Null until configured; the
  /// compliance overview displays the platform floor in that case.
  retentionRules Json?

  /// Workforce sourcing defaults for employer-mode tenants. Shape:
  ///   {
  ///     defaultSourcing: "hybrid" | "internal_only" | "external_only" | "open",
  ///     allowOpenMarket: boolean,
  ///     requireMentorForInternal: boolean
  ///   }
  workforcePolicy Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft delete. Tenants are never hard-deleted (audit trail integrity).
  deletedAt DateTime?

  // Back-references from tenant-scoped tables
  users               User[]
  acceptanceDecisions AcceptanceDecision[]
  paymentOrders       PaymentOrder[]
  paymentEvents       PaymentEvent[]
  userRoles           UserRole[]
  sessions            Session[]
  auditEvents         AuditEvent[]
  agentInvocations    AgentInvocation[]
  notifications       Notification[]
  sows                Sow[]
  sowVersions         SowVersion[]         @relation("SowVersionTenant")
  approvals           Approval[]           @relation("ApprovalTenant")
  sowTemplates        SowTemplate[]        @relation("SowTemplateTenant")
  decompositionPlans  DecompositionPlan[]  @relation("DecompositionPlanTenant")
  milestones          Milestone[]          @relation("MilestoneTenant")
  taskDefinitions     TaskDefinition[]     @relation("TaskDefinitionTenant")
  taskDependencies    TaskDependency[]     @relation("TaskDependencyTenant")
  submissions         Submission[]         @relation("SubmissionTenant")
  submissionArtifacts SubmissionArtifact[] @relation("SubmissionArtifactTenant")
  payouts             PayoutRecord[]       @relation("PayoutTenant")
  credentials         Credential[]         @relation("CredentialTenant")
  mentorshipSessions  MentorshipSession[]  @relation("MentorshipTenant")
  mentorshipNotes     MentorshipNote[]     @relation("MentorshipNoteTenant")
  safetyReports       SafetyReport[]       @relation("SafetyReportTenant")

  @@index([status])
  @@index([slug])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  provider      String?
  firstName     String
  lastName      String   @default("")
  role          String   @default("contributor")
  phone         String?
  emailVerified Boolean  @default(false)
  phoneVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Tenant this user belongs to. Null for cross-tenant users:
  ///   - contributors (work across multiple tenants)
  ///   - mentors (review across multiple tenants)
  ///   - platform admins (Glimmora staff)
  /// Enterprise users (sponsor, pmo, finance, etc.) MUST have tenantId.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  contributorProfile      ContributorProfile?
  userRoles               UserRole[]
  sessions                Session[]
  trustedDevices          TrustedDevice[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  ownedSows               Sow[]                    @relation("SowOwner")
  contributorSkills       ContributorSkill[]       @relation("ContributorSkills")
  mentorProfile           Mentor?                  @relation("MentorProfile")
  assignedTasks           TaskDefinition[]         @relation("AssignedContributor")
  internalReviewerTasks   TaskDefinition[]         @relation("InternalReviewer")
  submissions             Submission[]             @relation("SubmissionContributor")
  reviewedSubmissions     Submission[]             @relation("SubmissionReviewer")
  enterpriseReviewedSubmissions Submission[]       @relation("SubmissionEnterpriseReviewer")
  payoutMethods           PayoutMethod[]           @relation("PayoutMethodUser")
  payouts                 PayoutRecord[]           @relation("PayoutContributor")
  credentials             Credential[]             @relation("CredentialContributor")
  mentorshipSessionsAsMentor      MentorshipSession[] @relation("MentorshipMentor")
  mentorshipSessionsAsContributor MentorshipSession[] @relation("MentorshipContributor")
  mentorshipNotesAsMentor         MentorshipNote[]    @relation("MentorshipNoteMentor")
  mentorshipNotesAsContributor    MentorshipNote[]    @relation("MentorshipNoteContributor")
  filedSafetyReports              SafetyReport[]      @relation("SafetyReportReporter")
  assignedSafetyReports           SafetyReport[]      @relation("SafetyReportAssignee")
  kycChecks                       KycCheck[]          @relation("KycContributor")
  assignedKycChecks               KycCheck[]          @relation("KycAssignee")

  @@index([tenantId])
}

/// Role definition. Roles are scoped (contributor, mentor, enterprise,
/// platform) and bundle a set of permissions. Users can hold multiple
/// roles across scopes (e.g., ent.sponsor + ent.reviewer for the same
/// tenant; or mentor + plat.mpm for a Glimmora staff member who also
/// reviews).
///
/// `mutuallyExclusiveWith` is a soft separation-of-duties (SoD) signal —
/// admins assigning these in tandem see a warning, not a hard block
/// (per locked decision: warn-not-block).
model Role {
  code        String @id // e.g., 'ent.sponsor', 'mentor.lead', 'plat.tsm'
  scope       String // 'contributor' | 'mentor' | 'enterprise' | 'platform'
  description String

  /// Role codes that should not be assigned together to the same user.
  /// SoD soft-warning at assignment time.
  mutuallyExclusiveWith String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([scope])
}

/// Permission catalog. Permissions follow `<action>.<resource>` pattern
/// (e.g., 'create.sow', 'approve.sow.legal', 'update.rate_card').
///
/// `.self` suffix marks self-service permissions (read.profile.self,
/// update.profile.self, etc.) — granted to every authenticated role.
model Permission {
  code        String @id // e.g., 'create.sow'
  resource    String // 'sow' | 'rate_card' | 'task' | ...
  action      String // 'create' | 'read' | 'update' | 'delete' | 'approve' | ...
  description String

  createdAt DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
}

/// Many-to-many: which permissions each role has.
model RolePermission {
  roleCode       String
  permissionCode String
  grantedAt      DateTime @default(now())

  role       Role       @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  permission Permission @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@id([roleCode, permissionCode])
  @@index([permissionCode])
}

/// Many-to-many: which roles each user holds, optionally scoped to a
/// tenant. Enterprise roles (ent.*) require a tenantId. Cross-tenant
/// roles (mentor.*, plat.*, contributor) have tenantId = null.
///
/// Uniqueness is enforced via two partial unique indexes (with-tenant
/// + without-tenant) created in the migration SQL — Postgres treats
/// NULL ≠ NULL, so a single composite unique would allow duplicates.
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleCode  String
  tenantId  String?
  grantedAt DateTime @default(now())
  grantedBy String? // userId of who granted (for audit)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleCode], references: [code], onDelete: Restrict)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleCode])
  @@index([tenantId])
}

/// Durable session record. While NextAuth uses JWT for cookie payload,
/// we persist every session here so:
///
///   - **Logout**: setting `revokedAt` invalidates the session even if
///     the JWT hasn't expired yet. Middleware rejects any session with
///     `revokedAt != null`.
///   - **Multi-device management**: a user can list active sessions in
///     settings and revoke individual ones.
///   - **Idle timeout**: per-tenant policy may shorten the effective
///     session window (e.g., 8h from default 30 days). `lastActiveAt`
///     + tenant policy drive this.
///   - **Bulk revocation**: password change, mentor suspension, tenant
///     pause all bulk-set `revokedAt` for affected users.
///
/// Companion Redis blacklist (built later) caches recently-revoked
/// session IDs with TTL = remaining lifetime so middleware can do an
/// O(1) check without hitting Postgres on every request.
///
/// Per locked decision (Stage 0 #2): 30-day default, tenant-overridable
/// down to 8h.
model Session {
  id       String  @id @default(cuid())
  userId   String
  tenantId String?

  /// Cryptographic hash of the session token. Raw token is never stored;
  /// only the hash for cookie validation if JWT is bypassed.
  tokenHash String @unique

  /// Device fingerprint cookie value — links session to TrustedDevice
  /// when MFA is bypassed via the "trust this device" flow.
  deviceFingerprint String?

  /// Source of the session for forensic + admin views.
  ipAddress String?
  userAgent String?

  /// Was MFA verified during this session's login? Some routes require
  /// re-verification (e.g., audit-grade actions per doc 05 §13.4).
  mfaVerified Boolean @default(false)

  /// Heartbeat from the client — drives idle timeout per tenant policy.
  lastActiveAt DateTime @default(now())

  /// Session expiry. `min(issuedAt + 30d, tenant policy)`.
  expiresAt DateTime

  /// Revocation. Middleware MUST reject any session with revokedAt set.
  revokedAt     DateTime?
  /// Why revoked. Enum values:
  ///   "user_logout" | "password_change" | "admin_revoke" |
  ///   "tenant_paused" | "user_suspended" | "session_expired" |
  ///   "device_untrusted"
  revokedReason String?
  /// Who revoked. userId of the admin who force-revoked, or null for
  /// self / system revocations.
  revokedBy     String?

  issuedAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([revokedAt])
  @@index([expiresAt])
}

/// Trusted device record — when a user checks "trust this device for 30
/// days" during MFA, we persist the device fingerprint here. Subsequent
/// logins from the same fingerprint skip MFA until `trustedUntil`.
///
/// Distinct from Session because:
///   - A trusted device persists across multiple logins (multiple Sessions)
///   - Revoking a device should revoke all current Sessions tied to it +
///     prevent future MFA bypass
///
/// One row per (user, device fingerprint). User can list + revoke devices
/// in settings.
model TrustedDevice {
  id                String    @id @default(cuid())
  userId            String
  deviceFingerprint String
  /// User-friendly label, e.g. "MacBook Pro · home" or browser/OS derived.
  label             String?
  /// MFA bypass valid until this timestamp.
  trustedUntil      DateTime
  lastSeenAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  /// Revoked devices retain their row for audit but no longer bypass MFA.
  revokedAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@index([trustedUntil])
}

/// Immutable, append-only audit log.
///
/// Every consequential action in the platform writes here (see doc 05 §4.4
/// for the catalog: SOW changes, decompositions, task lifecycle, reviews,
/// payouts, role grants, tenant provisioning, AI overrides, etc.).
///
/// Audit writes are **synchronous** for state-changing actions — if the
/// audit fails, the action fails. This guarantees no undocumented mutation.
///
/// Storage guarantees:
///   - Postgres triggers (defined in migration SQL) reject UPDATE/DELETE
///     on this table. Even a superuser-connected app cannot mutate rows.
///   - Each row signed via HMAC; signature column captures the digest.
///   - Daily snapshot to S3 with object lock (infra, not schema).
///   - Retention 7 years floor per locked decision; tenant-configurable
///     longer.
///
/// `id` uses UUID with @default(uuid()) for a v4 fallback; the application
/// SHOULD mint UUIDv7 (time-orderable) and pass it explicitly — Prisma
/// doesn't have a native UUIDv7 generator yet (as of v7.x).
model AuditEvent {
  id String @id @default(uuid())

  /// Tenant scope. Null for platform-internal events (e.g., tenant
  /// provisioning itself). All other events MUST set tenantId.
  tenantId String?

  /// Actor identity at time of action. For system-fired events, use the
  /// reserved id "system".
  actorUserId     String
  actorPortalRole String // e.g., 'ent.sponsor', 'mentor.lead', 'plat.tsm'
  actorSessionId  String? // links to Session for forensics
  actorIpAddress  String?
  actorUserAgent  String?

  /// Dotted action verb, e.g. 'sow.approve', 'review.accept',
  /// 'rate_card.activate'. See doc 05 §4.4 for the action catalog.
  action String

  /// Resource being acted upon.
  resourceType  String // 'sow' | 'task' | 'review' | 'payout' | etc.
  resourceId    String
  /// Human-readable label, cached here so audit UI doesn't need to
  /// join into the resource table (which may have been deleted).
  resourceLabel String?

  /// Action-specific data.
  payload Json

  /// State diff: pre/post snapshots for state transitions.
  before Json?
  after  Json?

  /// 'info' | 'warning' | 'error' | 'critical'
  severity String @default("info")

  /// HMAC-SHA256 signature of canonical event JSON. Verified at read
  /// time; tampering breaks verification.
  signature         String?
  /// Key version used to sign (for key rotation; default 1).
  signingKeyVersion Int     @default(1)

  /// Event time. Drives time-range queries + the canonical sort order.
  timestamp DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, timestamp(sort: Desc)])
  @@index([actorUserId, timestamp(sort: Desc)])
  @@index([resourceType, resourceId, timestamp(sort: Desc)])
  @@index([action])
  @@index([severity])
  @@index([timestamp(sort: Desc)])
}

model ContributorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contribType        String
  country            String
  dob                DateTime
  timezone           String
  departmentCategory String
  departmentOther    String?
  primarySkills      String[]
  secondarySkills    String[]
  otherSkills        String[]
  availability       String
  degree             String?
  branch             String?
  linkedin             String?
  /** Student track — faculty supervisor chosen at onboarding. */
  supervisorEmail      String?
  supervisorName       String?
  /** Set when partnership admin approves participation for the term. */
  supervisorApprovedAt DateTime?
  /** Set when platform admin approves identity verification (freelancer / women WF). */
  kycVerifiedAt        DateTime?
  careerStage        String?
  yearsExperience    String?
  workStart          String?
  workEnd            String?

  ndaAccepted    Boolean @default(false)
  ndaSignature   String  @default("")
  acceptTos      Boolean @default(false)
  acceptCoc      Boolean @default(false)
  acceptPrivacy  Boolean @default(false)
  acceptFee      Boolean @default(false)
  acceptAhp      Boolean @default(false)
  marketingOptIn Boolean @default(false)

  /// Set when contributor opts in to peer mentorship matching.
  mentorshipOptInAt DateTime?
  /// Free-text focus area for the next assigned session.
  mentorshipFocus     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Audit log of enterprise acceptance / rework decisions on a delivery.
///
/// This is the truly-persistent half of the closure lifecycle —
/// every decision the enterprise makes on a mentor-cleared delivery
/// is recorded here, regardless of what the unified task store does
/// in browser localStorage. Survives logout, session reset, and
/// cross-device usage.
///
/// The decision is *additive*: the route handler does not mutate any
/// other entity. Reading the latest decision per taskId yields the
/// current enterprise verdict on that delivery.
model AcceptanceDecision {
  id              String   @id @default(cuid())
  /// Task id from the unified contributor task store (currently mock-only).
  /// Stored as a free string until the Task model itself is migrated to Prisma.
  taskId          String
  /// M19: link to the Submission this decision applies to. Nullable
  /// because pre-M19 rows reference free-text taskId only. New rows
  /// going through the M19 enterprise-review flow always have this set.
  submissionId    String?
  /// "accept" closes the lifecycle; "rework" returns to contributor.
  decision        String
  /// Optional note (acceptance) or required reason (rework).
  note            String?
  /// Reviewer/operator who decided. Today: initials; later: User.id reference.
  deciderId       String?
  deciderInitials String?
  decidedAt       DateTime @default(now())

  /// Tenant this decision belongs to. Enterprise decisions are always
  /// tenant-scoped. Nullable during initial migration; later migration
  /// backfills existing rows + tightens to NOT NULL.
  tenantId String?
  tenant   Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submission Submission? @relation("SubmissionEnterpriseDecisions", fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([taskId, decidedAt])
  @@index([submissionId, decidedAt])
  @@index([deciderId])
  @@index([tenantId, decidedAt])
}

/// Payment order intent — created when create-order is called, before
/// the user is sent to Razorpay checkout. Links the future payment
/// event back to the task being paid for (so the webhook handler can
/// reconcile without trusting client-supplied notes alone).
model PaymentOrder {
  id              String    @id @default(cuid())
  /// Razorpay's order id (e.g. "order_AbCdEf123"). Unique per order.
  razorpayOrderId String    @unique
  /// Task being paid for (free string until Task migrates to Prisma).
  taskId          String
  /// Initiating user — typically enterprise approver.
  initiatedById   String?
  /// Amount in the smallest currency unit (paise for INR). Razorpay's convention.
  amountMinor     Int
  currency        String    @default("INR")
  /// Lifecycle status. Driven by webhook events; "created" until webhook arrives.
  status          String    @default("created")
  /// Razorpay-side receipt id for cross-system tracing.
  receipt         String?
  /// Free-form metadata copied to Razorpay notes.
  notes           Json?
  /// Resolution timestamps — set when webhook events update the order.
  paidAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// Tenant this order belongs to. Nullable during initial migration;
  /// later migration backfills + tightens to NOT NULL.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([status])
  @@index([initiatedById])
  @@index([tenantId])
}

/// Webhook event audit log — every event we receive from Razorpay,
/// idempotency-keyed on its event id so retried deliveries (which
/// Razorpay does aggressively) don't double-process.
model PaymentEvent {
  id                String   @id @default(cuid())
  /// Razorpay's `x-razorpay-event-id` header. Unique = idempotent.
  razorpayEventId   String   @unique
  /// e.g. "payment.captured", "payment.failed", "order.paid"
  eventType         String
  /// Linkage to PaymentOrder when the event references one. Null for
  /// account-level events.
  razorpayOrderId   String?
  /// Razorpay's payment id, when applicable.
  razorpayPaymentId String?
  /// Full webhook body for forensic auditing. Capped at DB column max.
  rawPayload        Json
  /// True if signature verification passed. Failures are stored for
  /// monitoring (someone is probing the webhook).
  signatureValid    Boolean
  receivedAt        DateTime @default(now())

  /// Tenant this event belongs to. Nullable during initial migration;
  /// can also be null for account-level webhook events not tied to a tenant.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([razorpayOrderId])
  @@index([eventType, receivedAt])
  @@index([tenantId])
}

/// AI agent registry — the 4 MVP agents per SOW §3.1.MVP.7.
///
///   sow-intake          — extracts SOW metadata, flags hallucination risk
///   decomposition       — suggests milestones + tasks + skill tags
///   contributor-support — workroom AI signals (criteria progress, readiness)
///   review-assistant    — pre-fills mentor rubric scores
///
/// Each row is the configuration knob platform-admin (plat.ai) can
/// toggle on/off + change the active prompt for. Agent behavior is
/// implemented in `src/lib/ai/agents/<id>.ts`.
///
/// Per locked decision #8: Phase 1 = enable/disable + model id + active
/// prompt + rollback ONLY. Risk tiers + autonomy config + bias
/// monitoring deferred to Phase 2.
model Agent {
  id          String  @id // 'sow-intake' | 'decomposition' | ...
  name        String
  description String
  isEnabled   Boolean @default(true)
  modelId     String  @default("claude-sonnet-4-6")

  /// Active prompt version. Null while initial seed is running (chicken/egg).
  activePromptId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  promptTemplates PromptTemplate[]
  invocations     AgentInvocation[]
  activePrompt    PromptVersion?    @relation("ActivePrompt", fields: [activePromptId], references: [id], onDelete: SetNull)
}

/// Named prompt template per agent. An agent can have multiple
/// templates (e.g., review-assistant has `score-rubric` and may add
/// `summarize` later). Each template has many versions; only one is
/// active at a time per agent.
model PromptTemplate {
  id          String   @id @default(cuid())
  agentId     String
  name        String // e.g., 'score-rubric'
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent    Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versions PromptVersion[]

  @@unique([agentId, name])
  @@index([agentId])
}

/// Immutable prompt version. Rolling back to a prior version re-activates
/// it (changes Agent.activePromptId), doesn't mutate the row. New tuning
/// = new version row.
model PromptVersion {
  id               String   @id @default(cuid())
  promptTemplateId String
  /// Monotonic per template, starts at 1.
  version          Int
  body             String
  /// JSON-schema-like spec of expected output. Used at orchestrator
  /// time to validate agent output before returning to caller.
  expectedSchema   Json?
  /// Variable names the prompt expects. Caller MUST provide all of them.
  variables        String[] @default([])
  /// Free-form notes (rollback reason, tuning hints, eval scores).
  notes            String?
  /// userId of the prompt author / activator.
  createdBy        String?
  createdAt        DateTime @default(now())

  promptTemplate PromptTemplate    @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)
  activeOnAgents Agent[]           @relation("ActivePrompt")
  invocations    AgentInvocation[]

  @@unique([promptTemplateId, version])
  @@index([promptTemplateId])
}

/// Every agent call writes a row here. Persistent record of input,
/// output, confidence, latency, cost, status. Feeds the per-invocation
/// audit events (`agent.invoke` + `agent.respond`) and Phase 2
/// calibration analytics.
model AgentInvocation {
  id              String  @id @default(cuid())
  agentId         String
  /// Null when invocation failed before the prompt was resolved
  /// (agent disabled, missing config, etc.).
  promptVersionId String?
  modelId         String

  /// Tenant scope for the invocation. Null for system / cross-tenant calls.
  tenantId    String?
  actorUserId String

  /// Idempotency key. Same key returns the cached response within the
  /// 24h window (locked decision #18).
  requestId String @unique

  /// Caller-supplied input variables. Stored for forensic + calibration.
  input  Json
  /// Agent output (when status='success').
  output Json?

  /// 0..1 confidence; null when status != 'success'.
  confidence Float?

  /// Wall-clock from invokeAgent() start to response (or failure).
  latencyMs Int

  /// 'success' | 'error' | 'timeout' | 'rejected' | 'fallback'
  status       String
  errorMessage String?

  /// LLM cost in cents (Phase 2 calibrated; null for Phase 1 mocks).
  costCents Int?

  createdAt DateTime @default(now())

  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Restrict)
  promptVersion PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([agentId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([status])
}

/// In-app notification record + cross-channel dispatch tracking.
///
/// Per locked decision #9: SMS reserved for critical events only
/// (password change, safety case ack, payout failure). Email + in-app
/// for everything important.
///
/// Lifecycle: dispatch fires → row inserted with `dispatchedAt` →
/// in_app delivery is immediate (just persistence). Email/SMS land
/// channel-deliveredAt timestamps when the provider acknowledges.
/// `readAt` is set when the recipient marks it read.
model Notification {
  id              String  @id @default(cuid())
  recipientUserId String
  tenantId        String?

  /// One of ~26 NotificationKind values — see src/lib/notifications/types.ts
  kind     String
  /// 'critical' | 'important' | 'informational' — drives default channels
  severity String @default("informational")

  /// Payload fields. Flattened (not JSON) so we can index/filter by them.
  title        String
  body         String
  actionUrl    String?
  actionLabel  String?
  resourceType String?
  resourceId   String?

  /// Channels this notification was actually dispatched to.
  channels String[] @default([])

  dispatchedAt     DateTime  @default(now())
  deliveredInAppAt DateTime?
  deliveredEmailAt DateTime?
  deliveredSmsAt   DateTime?
  readAt           DateTime?

  recipient User    @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, dispatchedAt(sort: Desc)])
  @@index([recipientUserId, readAt])
  @@index([tenantId])
  @@index([kind])
}

/// Per-user, per-kind channel preferences. When a row is absent, the
/// system uses the kind's default channel set (driven by severity).
///
/// Critical-severity channels are always locked on (in_app + email at
/// minimum) — user preferences can't disable them.
model NotificationPreference {
  id       String   @id @default(cuid())
  userId   String
  kind     String
  channels String[] @default(["in_app"])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId])
}

/// Statement of Work — the originating entity in the SOW lifecycle.
///
/// Per SOW §3.1.MVP.1 + doc 02 §5.C. Versioning is via `SowVersion`
/// (immutable snapshots); the `activeVersion` int points to the
/// currently-displayed version row.
///
/// Lifecycle (status field):
///   draft → approval → approved
///                    → rejected
///                    → withdrawn
///   any → archived (soft-delete, distinct from rejected)
///
/// Approval pipeline within status='approval' (stage field):
///   commercial → final → approved
///   (send back from commercial → draft, or reject → rejected)
model Sow {
  id String @id @default(cuid())

  /// Tenant-scoped — RLS enforces isolation.
  tenantId String

  /// Display title. Denormalized from active version for fast list queries.
  title String

  /// 'draft' | 'approval' | 'approved' | 'rejected' | 'withdrawn' | 'archived'
  status String @default("draft")

  /// Active approval stage when status='approval'. Null otherwise.
  /// 'commercial' | 'final'
  stage String?

  /// Active version number — points to the currently-displayed SowVersion.
  activeVersion Int @default(1)

  /// Sponsor (the SOW owner). FK to User.
  ownerId String

  /// 'standard' | 'confidential' | 'restricted'
  confidentiality String @default("standard")

  /// Lifecycle timestamps — set when status transitions occur.
  submittedForApprovalAt DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  withdrawnAt            DateTime?
  archivedAt             DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  owner     User         @relation("SowOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  versions  SowVersion[]
  approvals Approval[]
  decompositionPlans DecompositionPlan[] @relation("DecompositionPlanSow")

  @@index([tenantId, status])
  @@index([tenantId, updatedAt(sort: Desc)])
  @@index([ownerId])
  @@index([stage])
}

/// Immutable snapshot of a SOW at a point in time.
///
/// New version created on every meaningful edit (or on send-back from
/// an approval stage). `supersededAt` is set when a newer version
/// activates. Audit + approval rows reference a specific version so
/// later edits don't rewrite history.
model SowVersion {
  id      String @id @default(cuid())
  sowId   String
  /// Monotonic per SOW, starts at 1.
  version Int

  /// Denormalized for RLS — same as Sow.tenantId.
  tenantId String

  /// Full payload snapshot — extracted metadata, deliverables, clauses,
  /// risk scores. JSON for flexibility during Phase 1 shape settling.
  payload Json

  /// Free-text body / extracted SOW document text.
  body String?

  /// What changed vs the previous version (caller-supplied).
  changeNote String?

  /// User who authored this version.
  createdBy String
  createdAt DateTime @default(now())

  /// Set when a newer version activates. Null = current active.
  supersededAt DateTime?

  sow    Sow    @relation(fields: [sowId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("SowVersionTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([sowId, version])
  @@index([sowId])
  @@index([tenantId])
}

/// Per-stage approval decision record (two gates):
///   commercial → final
///
/// Each stage gets a pending row when status enters that stage; the
/// approver fills in decision + comment + decidedAt. Send-back creates
/// a new pending row when the SOW returns to that stage.
model Approval {
  id    String @id @default(cuid())
  sowId String

  /// SOW version this approval was decided against — preserves linkage
  /// even if a new version is created later.
  sowVersion Int

  /// Denormalized for RLS — same as Sow.tenantId.
  tenantId String

  /// 'commercial' | 'final'
  stage String

  /// Approver: User.id when known. Free string until approver-routing
  /// policy lands (could resolve to role code or team handle).
  approverId String?

  /// 'pending' | 'approve' | 'reject' | 'send_back'
  decision String @default("pending")

  /// Comment / reject reason / send-back required-corrections.
  comment String?

  decidedAt DateTime?
  createdAt DateTime  @default(now())

  /// SLA deadline — set when the stage starts.
  slaDeadline DateTime?

  sow    Sow    @relation(fields: [sowId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("ApprovalTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([sowId, stage])
  @@index([approverId])
  @@index([decision])
  @@index([tenantId])
}

/// Configurable SOW intake template. Two scopes:
///   - tenantId = null   → platform-wide template (Software, Marketing, etc.)
///   - tenantId = string → tenant-specific override
///
/// Templates ship default sections, approver chains, risk thresholds,
/// and SLA windows. Phase 1 ships 2 platform templates; tenants can
/// clone + customize.
model SowTemplate {
  id          String  @id @default(cuid())
  /// Null = platform-wide template available to all tenants.
  tenantId    String?
  name        String
  description String?

  /// Default sections / required fields / approver chain — JSON spec.
  spec Json

  /// Default risk thresholds, SLAs per stage. JSON; shape stabilizes
  /// when policy templates table lands (M11+).
  defaults Json?

  /// Default template for new SOWs in this scope.
  isDefault Boolean @default(false)

  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant? @relation("SowTemplateTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isDefault])
}

/// ─────────────────────────────────────────────────────────────────
/// M10 — Skill taxonomy + Mentor pool
/// ─────────────────────────────────────────────────────────────────
///
/// All four tables are platform-wide (no tenantId, no RLS). Skills
/// are a global vocabulary; contributors claim them across tenants;
/// mentors review across tenants. RLS would actively get in the way
/// since contributors and mentors are explicitly cross-tenant
/// (per doc 05 §3.1 and locked decision #6).
///
/// Access control is permission-based at the application layer:
///   - read.skill            (all authenticated)
///   - manage.skill          (plat.admin)
///   - read.mentor_pool      (admin/mentor.*)
///   - manage.mentor_pool    (plat.admin)
///   - claim.contributor_skill (own claims)
///   - read.contributor_skill (own + mentor.* + admin)

/// Hierarchical skill taxonomy. Categories at the top; child skills
/// (parentId set) sit underneath. Used by the matching engine, the
/// mentor-routing system, and the contributor profile evidence pages.
model Skill {
  id          String  @id @default(cuid())
  /// URL-safe slug — used by API endpoints and external integrations.
  /// Unique across the whole taxonomy.
  code        String  @unique
  name        String
  /// Optional category grouping. When parentId is null + category
  /// non-null, this row IS a category root (visual grouping).
  category    String?
  /// Self-referential hierarchy. Two levels deep in Phase 1; deeper
  /// nesting allowed but not exercised.
  parentId    String?
  description String?
  /// Whether the matching engine should weight this skill positively
  /// when scoring candidates. Disabled skills survive in history but
  /// aren't surfaced as suggestions.
  active      Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent   Skill?  @relation("SkillHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Skill[] @relation("SkillHierarchy")

  contributorClaims ContributorSkill[]
  mentorClaims      MentorSkill[]

  @@index([category])
  @@index([parentId])
  @@index([active])
}

/// Contributor-claimed skill with a level + source. Source distinguishes
/// self-declared vs assessment-verified vs platform-issued. The
/// matching engine weights verified higher than self-declared.
model ContributorSkill {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  level     String   @default("intermediate") // 'beginner' | 'intermediate' | 'advanced' | 'expert'
  /// Source of the claim. Trust order: verified > assessment > self.
  source    String   @default("self") // 'self' | 'assessment' | 'verified'
  /// Optional 0-100 proficiency score from an assessment. Null for
  /// pure self-claims.
  proficiencyScore Int?
  evidenceUrl      String?
  declaredAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User  @relation("ContributorSkills", fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@index([level])
  @@index([source])
}

/// Mentor profile — the cross-tenant identity that reviews work and
/// runs mentorship sessions. Built on the existing User row; this
/// table holds review-specific metadata (capacity, status, etc.).
///
/// One Mentor per User (1:1 via userId @unique). The User.role
/// already says 'reviewer' for these users; this table adds the
/// review-domain state machine.
model Mentor {
  id     String @id @default(cuid())
  userId String @unique
  /// 'active' = available for new assignments
  /// 'paused' = no new assignments (vacation, training)
  /// 'inactive' = removed from pool (don't show in selectors)
  status String @default("active")
  /// Self-reported weekly capacity. Used by the matching/assignment
  /// engine to balance load. 0 = no cap; null = not declared yet.
  capacityHoursPerWeek Int?
  /// Free-form bio shown to enterprise users selecting reviewers.
  bio String?
  /// Time zone for scheduling mentorship sessions (IANA name).
  timezone String?
  /// Whether this mentor is willing to take women-WF / student
  /// mentorship sessions (per doc 05 §10).
  acceptsMentorshipSessions Boolean @default(true)

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("MentorProfile", fields: [userId], references: [id], onDelete: Cascade)

  skills MentorSkill[]

  @@index([status])
  @@index([acceptsMentorshipSessions])
}

/// Which skills a mentor is qualified to review. Drives the routing
/// engine that assigns submissions to mentors with matching expertise.
model MentorSkill {
  id        String   @id @default(cuid())
  mentorId  String
  skillId   String
  /// 'lead'  — primary expertise; preferred routing
  /// 'depth' — strong expertise; standard routing
  /// 'aware' — secondary expertise; overflow routing only
  depth     String   @default("depth")
  declaredAt DateTime @default(now())

  mentor Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([mentorId, skillId])
  @@index([mentorId])
  @@index([skillId])
  @@index([depth])
}

/// ─────────────────────────────────────────────────────────────────
/// M11 — Decomposition tables
/// ─────────────────────────────────────────────────────────────────
///
/// Persists the output of the Decomposition Assistant (AI agent) +
/// the PMO's edits. A plan belongs to a SOW; milestones group tasks
/// within a plan; tasks are the atomic units the matching engine
/// routes to contributors.
///
/// All four tables are tenant-scoped via a denormalized tenantId
/// column with RLS enforcing the standard `app.tenant_id` policy
/// (matches M5 + M8 patterns).

/// One plan per SOW, but multiple plan VERSIONS may exist as the
/// PMO refines the AI output. `version` increments on each save;
/// `status` advances draft → approved → active → archived.
model DecompositionPlan {
  id       String @id @default(cuid())
  sowId    String
  tenantId String
  /// Monotonic per-SOW version. The PMO can roll back to an earlier
  /// version while still in draft.
  version  Int    @default(1)
  /// 'draft'    — PMO editing
  /// 'approved' — sponsor signed off; ready to provision
  /// 'active'   — provisioned; tasks live in the contributor queues
  /// 'archived' — superseded or project closed
  status   String @default("draft")
  /// Free-form summary the PMO writes when sharing with the sponsor.
  summary  String?

  /// Source agent invocation that produced the AI suggestions (when
  /// applicable). Links to AgentInvocation.id for traceability.
  sourceAgentInvocationId String?

  /// Sign-off metadata
  approvedAt      DateTime?
  approvedBy      String?
  activatedAt     DateTime?
  archivedAt      DateTime?
  createdBy       String

  /// Default workforce sourcing for tasks in this plan when task-level
  /// value is unset: hybrid | internal_only | external_only | open
  defaultWorkforceSourcing String?
  /// Fallback review path when task is silent: mentor | internal
  defaultReviewPath        String?
  /// When true, mentor accept fans out to ent.reviewer (Decision #5).
  twoStageReviewEnabled    Boolean @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sow    Sow    @relation("DecompositionPlanSow", fields: [sowId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("DecompositionPlanTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  milestones Milestone[]
  tasks      TaskDefinition[]

  @@unique([sowId, version])
  @@index([sowId])
  @@index([tenantId, status])
  @@index([status])
}

/// Phase-level grouping within a plan. Order field drives sort.
model Milestone {
  id       String @id @default(cuid())
  planId   String
  tenantId String

  /// Display order within the plan (1-indexed).
  order    Int
  name     String
  description String?

  /// Optional target dates the sponsor agrees to.
  startDate DateTime?
  endDate   DateTime?

  /// Status follows the project lifecycle once the plan is active.
  /// 'pending' | 'in_progress' | 'completed' | 'at_risk' | 'blocked'
  status   String  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan   DecompositionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenant Tenant            @relation("MilestoneTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  tasks  TaskDefinition[]

  @@unique([planId, order])
  @@index([planId])
  @@index([tenantId])
  @@index([status])
}

/// Atomic units of work that the matching engine routes to contributors.
/// `requiredSkills` is a denormalized string[] of skill codes (e.g.
/// ['engineering.react', 'design.system']) — sized for Phase 1 query
/// speed without a join table.
model TaskDefinition {
  id          String @id @default(cuid())
  planId      String
  milestoneId String?
  tenantId    String

  /// Short identifier within the plan (e.g., "T-12"). Display only.
  externalKey String?
  title       String
  description String?

  /// Skill codes required to perform this task. Empty array = open
  /// to any contributor. Format matches Skill.code (slug).
  requiredSkills String[] @default([])

  /// Estimated effort in person-hours. Decimal supported (e.g. 2.5).
  estimatedHours Float?

  /// Acceptance criteria the contributor must satisfy. Markdown OK.
  acceptanceCriteria String?

  /// Suggested complexity for routing/pricing.
  /// 'small' | 'medium' | 'large' | 'xl'
  complexity String?

  /// Display order within milestone (1-indexed). Tasks across
  /// milestones use (milestone.order, task.order) for global sort.
  order Int @default(0)

  /// Lifecycle once the plan is active. Phase 1: planning rows only.
  /// 'draft' | 'ready' | 'matched' | 'in_progress' | 'submitted' | 'reviewed' | 'accepted' | 'cancelled'
  status String @default("draft")

  /// Optional confidence score from the AI agent (0-100).
  aiConfidence Int?
  /// Flag indicating the PMO edited the AI suggestion. Helps the
  /// trust-and-improvements feedback loop on the agent.
  pmoEdited Boolean @default(false)

  /// ── M15 assignment fields ───────────────────────────────────────
  /// The contributor currently assigned to this task. Null until the
  /// matching engine picks a candidate + the operator confirms.
  /// One contributor per task in Phase 1 (no co-work yet).
  assignedContributorId String?
  /// When the assignment was made (server-side; matching/operator action).
  assignedAt           DateTime?
  /// When the contributor accepted the assignment. Null until accept.
  acceptedAt           DateTime?

  /// ── M17 payout rate fields ──────────────────────────────────────
  /// Per-hour rate agreed at assignment time. Snapshotted onto the task
  /// so subsequent rate-card changes don't retroactively alter payouts.
  /// Null = use default platform rate when computing payout.
  agreedRatePerHour    Float?
  /// ISO 4217 currency code; defaults to "INR" when amount applied.
  agreedCurrency       String?

  /// Who may be assigned: internal_only | internal_first | external_only | open
  workforceSourcing    String?
  /// Review chain: mentor | internal | mentor_then_internal | auto_accept
  reviewPath           String?
  /// Optional designated enterprise reviewer (manager delegate).
  internalReviewerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan      DecompositionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  milestone Milestone?        @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  tenant    Tenant            @relation("TaskDefinitionTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  assignedContributor User?   @relation("AssignedContributor", fields: [assignedContributorId], references: [id], onDelete: SetNull)
  internalReviewer    User?   @relation("InternalReviewer", fields: [internalReviewerId], references: [id], onDelete: SetNull)

  outgoingDeps TaskDependency[] @relation("TaskDepFrom")
  incomingDeps TaskDependency[] @relation("TaskDepTo")
  submissions  Submission[]
  payouts      PayoutRecord[]
  credentials  Credential[]

  @@index([planId])
  @@index([milestoneId])
  @@index([tenantId])
  @@index([status])
  @@index([assignedContributorId])
  @@index([reviewPath])
  // GIN index on requiredSkills set up via raw SQL in the migration.
}

/// DAG edges between task definitions within a plan. Phase 1 uses
/// only 'finish_to_start' — the most common dependency type; richer
/// semantics (start-start, lag/lead time) can be added in Phase 2.
model TaskDependency {
  id         String @id @default(cuid())
  fromTaskId String
  toTaskId   String
  tenantId   String
  /// 'finish_to_start' | 'start_to_start' | 'finish_to_finish'
  type       String @default("finish_to_start")

  createdAt DateTime @default(now())

  fromTask TaskDefinition @relation("TaskDepFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask   TaskDefinition @relation("TaskDepTo",   fields: [toTaskId],   references: [id], onDelete: Cascade)
  tenant   Tenant         @relation("TaskDependencyTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([fromTaskId, toTaskId, type])
  @@index([fromTaskId])
  @@index([toTaskId])
  @@index([tenantId])
}

/// ─────────────────────────────────────────────────────────────────
/// M15 — Submission persistence
/// ─────────────────────────────────────────────────────────────────
///
/// One Submission per (taskDefinitionId, version). Versions monotonic
/// per task; new version created when a contributor responds to mentor
/// feedback ("resubmit"). The "current" submission per task is the
/// one with the highest version that isn't in terminal status.
///
/// Tenant-scoped (denormalized tenantId from TaskDefinition) so RLS
/// can isolate cross-tenant rows without joins.
///
/// Status lifecycle (per criterion #10 + #11):
///   draft → submitted → under_review → (feedback_requested → resubmitted → under_review)*
///                                    → accepted (mentor green-lights)
///                                    → rejected
/// Terminal: accepted, rejected.
model Submission {
  id                  String @id @default(cuid())
  taskDefinitionId    String
  contributorId       String
  tenantId            String

  /// Monotonic version within (taskDefinitionId). Starts at 1.
  version             Int

  /// Workflow state.
  /// 'draft' | 'submitted' | 'under_review' | 'feedback_requested'
  /// | 'resubmitted' | 'accepted' | 'rejected'
  status              String  @default("draft")

  /// Optional markdown body the contributor writes.
  body                String?
  /// Free-form JSON payload (links, evidence URLs, structured data).
  payload             Json?

  /// Mentor assigned to review this submission. Set when mentor
  /// claims it from the queue.
  reviewerId          String?
  reviewerAssignedAt  DateTime?

  /// Stamps the moment of contributor commitment — submission becomes
  /// visible to mentor queue, body/payload become immutable until
  /// feedback_requested re-opens the loop.
  submittedAt         DateTime?
  /// When the mentor decided (accept / reject).
  decidedAt           DateTime?

  /// ── M16 mentor decision fields ─────────────────────────────────
  /// The AI rubric-assist suggestion captured at decision time.
  /// 'accept' | 'reject' | 'feedback_requested'. Null when mentor
  /// declined to consult the assistant for this submission.
  aiSuggestedDecision String?
  /// FK to the AgentInvocation row that produced the suggestion.
  /// Lets us trace which prompt/version was running when this
  /// decision was made (criterion #19: prompt rollback audit).
  aiInvocationId      String?
  /// Mentor's free-form rationale captured with the decision.
  decisionRationale   String?

  /// ── M19 enterprise-review claim fields ─────────────────────────
  /// Enterprise reviewer who has the submission open. Cleared on
  /// release. Null until claimed.
  enterpriseReviewerId          String?
  enterpriseReviewerAssignedAt  DateTime?
  /// When the enterprise reviewer recorded their final decision.
  /// Cross-references the latest AcceptanceDecision row via submissionId.
  enterpriseDecidedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  taskDefinition TaskDefinition @relation(fields: [taskDefinitionId], references: [id], onDelete: Cascade)
  contributor    User           @relation("SubmissionContributor", fields: [contributorId], references: [id], onDelete: Restrict)
  reviewer       User?          @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  enterpriseReviewer User?      @relation("SubmissionEnterpriseReviewer", fields: [enterpriseReviewerId], references: [id], onDelete: SetNull)
  tenant         Tenant         @relation("SubmissionTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  artifacts            SubmissionArtifact[]
  payout               PayoutRecord?
  credential           Credential?
  enterpriseDecisions  AcceptanceDecision[] @relation("SubmissionEnterpriseDecisions")

  @@unique([taskDefinitionId, version])
  @@index([contributorId])
  @@index([reviewerId])
  @@index([status])
  @@index([tenantId, status])
  @@index([submittedAt])
}

/// ─────────────────────────────────────────────────────────────────
/// M17 — Payout schema
/// ─────────────────────────────────────────────────────────────────
///
/// Two tables:
///   PayoutMethod  — contributor's withdrawal target (UPI / bank / etc).
///                   Cross-tenant; userId only. No RLS.
///   PayoutRecord  — one row per task-acceptance → payout cycle.
///                   Tenant-scoped (the tenant owes the money). Phase 1
///                   ships WITHOUT RLS on this table — contributor-self
///                   reads span tenants and the standard tenant-isolation
///                   policy would block them. Application layer enforces
///                   read scope (contributorId OR tenantId match) until
///                   the broader user-aware RLS pattern lands in Phase 2.

/// A contributor's withdrawal target. One default per user; multiple
/// records allowed so a contributor can switch between methods.
///
/// `payload` carries the kind-specific data:
///   bank_in:    { accountNumber, ifsc, accountHolder, bankName }
///   upi:        { vpa }
///   paypal:     { email }
///   razorpay_x: { fundAccountId }
///
/// Phase 1 stores payload as JSON in plaintext (no field-level
/// encryption yet); a follow-up migration will wrap this in
/// application-layer encryption with a KMS-managed key.
model PayoutMethod {
  id          String  @id @default(cuid())
  userId      String
  kind        String // 'bank_in' | 'upi' | 'paypal' | 'razorpay_x'
  nickname    String?
  payload     Json
  /// True for the default method used when the contributor doesn't
  /// specify one at withdrawal time. At most one default per user
  /// (enforced by service-layer logic + a uniqueness query).
  isDefault   Boolean @default(false)
  /// Verification status — bank/UPI rails may require a name-match
  /// check before payout. Null = unverified.
  verifiedAt  DateTime?
  /// Why it failed verification (if applicable). Cleared on success.
  verificationError String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user    User           @relation("PayoutMethodUser", fields: [userId], references: [id], onDelete: Cascade)
  payouts PayoutRecord[] @relation("PayoutMethodChosen")

  @@index([userId])
  @@index([userId, isDefault])
  @@index([kind])
}

/// One row per task-acceptance → payout cycle. Created when the mentor
/// flips a submission to 'accepted'. Lifecycle:
///   eligible → requested → processing → sent
///                                     → failed (retryable; status reverts to 'eligible')
///                                     → on_hold (T&S / KYC freeze)
///
/// `computation` records the inputs that produced `amount` so a payout
/// can be audited and reproduced even if rate cards change later.
model PayoutRecord {
  id               String @id @default(cuid())
  contributorId    String
  taskDefinitionId String
  submissionId     String  @unique
  tenantId         String

  /// Amount in the smallest currency unit (paise for INR, cents for USD).
  amountMinor      Int
  currency         String @default("INR")
  /// JSON snapshot of how amountMinor was derived. Phase 1 minimum:
  ///   { ratePerHour, estimatedHours, currency, tier?, multipliers? }
  computation      Json

  /// Lifecycle. See above.
  status           String @default("eligible")

  /// Optional payout method chosen at withdrawal request time.
  payoutMethodId   String?
  /// Optional reference to a Razorpay X fund-account/payout id once
  /// real integration lands. Null in Phase 1's mock mode.
  externalRef      String?
  /// Free-form reason when status is 'on_hold' or 'failed'.
  failureReason    String?

  /// Lifecycle timestamps. Eligible is set on creation.
  eligibleAt       DateTime  @default(now())
  requestedAt      DateTime?
  processingAt     DateTime?
  sentAt           DateTime?
  failedAt         DateTime?
  onHoldAt         DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  contributor    User           @relation("PayoutContributor", fields: [contributorId], references: [id], onDelete: Restrict)
  taskDefinition TaskDefinition @relation(fields: [taskDefinitionId], references: [id], onDelete: Restrict)
  submission     Submission     @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  tenant         Tenant         @relation("PayoutTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  payoutMethod   PayoutMethod?  @relation("PayoutMethodChosen", fields: [payoutMethodId], references: [id], onDelete: SetNull)

  @@index([contributorId])
  @@index([tenantId, status])
  @@index([taskDefinitionId])
  @@index([status])
  @@index([eligibleAt])
}

/// ─────────────────────────────────────────────────────────────────
/// M18 — Credential issuance
/// ─────────────────────────────────────────────────────────────────
///
/// One Credential per accepted submission. Auto-issued atomically with
/// the PayoutRecord when a mentor flips a submission to 'accepted'.
///
/// Like PayoutRecord, Credential is NOT RLS-protected — contributors
/// read their own credentials across tenants; public verify endpoints
/// resolve by `shareSlug`. Application layer enforces scope at the
/// route boundary.
///
/// Tamper detection: `content` carries the canonical JSON snapshot at
/// issuance time; `signature` is an HMAC-SHA256 over canonicalJson(content)
/// using AUDIT_SIGNING_KEY_V{signingKeyVersion}. Mutating the row breaks
/// signature verification on the public page.
model Credential {
  id               String @id @default(cuid())
  contributorId    String
  taskDefinitionId String
  submissionId     String  @unique
  tenantId         String

  /// 'issued' | 'revoked'
  status           String  @default("issued")
  /// Public URL-safe identifier. Anyone with the slug can view the
  /// credential. Unique across the platform.
  shareSlug        String  @unique

  /// Canonical content shown on the public + private views. JSON
  /// shape: { taskTitle, tenantName, contributorName, skills[],
  /// acceptedAt, mentorReviewedBy? }. Stable for signature verify.
  content          Json

  /// HMAC-SHA256(canonicalJson(content)) — hex.
  signature        String
  signingKeyVersion Int    @default(1)

  /// Short human-readable summary surfaced on cards.
  summary          String?
  /// Skills demonstrated — denormalized from task.requiredSkills at
  /// issue time for fast indexing + display.
  skills           String[] @default([])

  issuedAt         DateTime @default(now())
  revokedAt        DateTime?
  revokedBy        String?
  revokedReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributor    User           @relation("CredentialContributor", fields: [contributorId], references: [id], onDelete: Restrict)
  taskDefinition TaskDefinition @relation(fields: [taskDefinitionId], references: [id], onDelete: Restrict)
  submission     Submission     @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  tenant         Tenant         @relation("CredentialTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([contributorId])
  @@index([tenantId, status])
  @@index([status])
  @@index([issuedAt])
}

/// Files / links / evidence references attached to a Submission.
/// Multiple kinds:
///   - 'file'    — uploaded artifact (storage key in `url`)
///   - 'link'    — external URL (figma, github, deployed preview)
///   - 'evidence' — third-party trust signal (verified cert, public artifact)
///
/// Phase 1 stores URLs/keys only; actual file scan + storage
/// resolution lives in a separate service (Week 9 deliverable).
model SubmissionArtifact {
  id           String @id @default(cuid())
  submissionId String
  tenantId     String

  kind         String // 'file' | 'link' | 'evidence'
  name         String
  url          String
  mimeType     String?
  sizeBytes    Int?
  /// Optional caller-supplied label / description.
  caption      String?
  /// True after the scan service has cleared the artifact (clean
  /// + non-plagiarized). Phase 1 ships defaults to true for links.
  scanCleared  Boolean @default(false)
  /// When the scan service last attempted to scan this artifact.
  /// Null = never attempted. The file-scan worker sets this.
  scanAttemptedAt DateTime?
  /// Most recent scan failure reason. Null on clear or never-scanned.
  scanError       String?

  createdAt DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation("SubmissionArtifactTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([submissionId])
  @@index([tenantId])
  @@index([kind])
  @@index([scanCleared])
}

/// ─────────────────────────────────────────────────────────────────
/// M21 — Mentorship sessions + coaching notes
/// ─────────────────────────────────────────────────────────────────
///
/// A mentorship session pairs a Mentor with a Contributor for a
/// scheduled meeting (women-WF / student support per doc 05 §10).
/// Optionally tenant-scoped: a mentor working with a contributor on a
/// specific project may attach the session to that tenant; pure
/// career-growth sessions stay tenant=null.
///
/// Lifecycle:
///   scheduled → held       (mentor marks complete after the meeting)
///             → no_show    (contributor didn't attend)
///             → cancelled  (either side cancelled before the meeting)
model MentorshipSession {
  id              String @id @default(cuid())
  mentorId        String  // userId of the mentor
  contributorId   String  // userId of the contributor
  /// Tenant scope. Null for cross-tenant (career-growth) sessions.
  tenantId        String?

  scheduledAt     DateTime
  durationMinutes Int      @default(45)
  /// Free-form agenda the mentor + contributor agreed on.
  agenda          String?
  /// External meeting URL (Zoom / Meet / etc.).
  meetingLink     String?
  /// Optional location/timezone hint.
  timezone        String?

  /// 'scheduled' | 'held' | 'no_show' | 'cancelled'
  status          String   @default("scheduled")

  /// Set when status flips to 'held'.
  completedAt     DateTime?
  /// Set when status flips to 'cancelled'.
  cancelledAt     DateTime?
  cancelledBy     String?  // userId of who cancelled
  cancellationReason String?
  /// Set when status flips to 'no_show'.
  noShowAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  mentor      User    @relation("MentorshipMentor", fields: [mentorId], references: [id], onDelete: Restrict)
  contributor User    @relation("MentorshipContributor", fields: [contributorId], references: [id], onDelete: Restrict)
  tenant      Tenant? @relation("MentorshipTenant", fields: [tenantId], references: [id], onDelete: SetNull)

  notes MentorshipNote[]

  @@index([mentorId])
  @@index([contributorId])
  @@index([tenantId])
  @@index([scheduledAt])
  @@index([status])
  @@index([mentorId, status])
  @@index([contributorId, status])
}

/// Coaching note attached to a mentorship session (or standalone).
/// Visibility controls who can read it:
///   - 'private'  : mentor-only (their own working notes)
///   - 'shared'   : visible to the contributor in their profile
///   - 'public'   : visible on the contributor's public profile
///                  (e.g. a recommendation / endorsement)
model MentorshipNote {
  id            String @id @default(cuid())
  /// Nullable so the mentor can write a contributor-wide note
  /// without a specific session attached.
  sessionId     String?
  mentorId      String
  contributorId String
  /// Tenant scope mirrors the session when present.
  tenantId      String?

  body          String
  visibility    String  @default("private") // 'private' | 'shared' | 'public'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  session     MentorshipSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mentor      User               @relation("MentorshipNoteMentor",      fields: [mentorId], references: [id], onDelete: Restrict)
  contributor User               @relation("MentorshipNoteContributor", fields: [contributorId], references: [id], onDelete: Restrict)
  tenant      Tenant?            @relation("MentorshipNoteTenant",      fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([mentorId])
  @@index([contributorId])
  @@index([visibility])
  @@index([contributorId, visibility])
}

/// ─────────────────────────────────────────────────────────────────
/// M22 — Safety reports + governance triage
/// ─────────────────────────────────────────────────────────────────
///
/// A SafetyReport is filed by a user (typically a contributor) about
/// another user, task, submission, or tenant. The platform Trust &
/// Safety team triages via the governance queue.
///
/// Cross-tenant by design — a contributor working across tenants may
/// report on any of them. App-layer scoping enforces who can read
/// what; tenantId is informational (which tenant the subject lived
/// in when reported).
///
/// Status lifecycle:
///   open → triaging → resolved        (terminal — action recorded)
///                  → dismissed        (terminal — no action)
///                  → escalated_external (terminal — handed to legal/external)
model SafetyReport {
  id            String @id @default(cuid())
  reporterId    String  // userId of reporter
  /// What the report is about. 'user' | 'task' | 'tenant' | 'submission' | 'comment'
  subjectKind   String
  /// FK-ish string into the subject's domain (no DB-level FK because
  /// subjects span tenants, may be soft-deleted, and the report must
  /// outlive the subject for compliance reasons).
  subjectId     String
  /// Tenant of the subject when known (informational).
  tenantId      String?

  /// 'harassment' | 'fraud' | 'spam' | 'unsafe_work' | 'plagiarism' | 'other'
  category      String
  /// 'immediate' | 'high' | 'normal' | 'low'
  severity      String   @default("normal")
  description   String
  /// Optional structured evidence the reporter attached
  /// (URLs, screenshots, message ids, etc.).
  evidence      Json?

  /// 'open' | 'triaging' | 'resolved' | 'dismissed' | 'escalated_external'
  status        String   @default("open")

  /// T&S assignee currently triaging the report. Null when unclaimed.
  assigneeId    String?
  assignedAt    DateTime?

  /// Set at terminal status. resolution captures the action taken.
  decidedAt     DateTime?
  decidedBy     String?
  /// 'no_action' | 'warning_issued' | 'account_suspended' | 'content_removed'
  ///   | 'tenant_paused' | 'external_handoff' | 'duplicate'
  resolutionAction String?
  resolutionNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  reporter User    @relation("SafetyReportReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  assignee User?   @relation("SafetyReportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tenant   Tenant? @relation("SafetyReportTenant",   fields: [tenantId],   references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([assigneeId])
  @@index([status])
  @@index([severity, status])
  @@index([subjectKind, subjectId])
  @@index([tenantId])
  @@index([createdAt])
}

/// ─────────────────────────────────────────────────────────────────
/// M23 — KYC review queue
/// ─────────────────────────────────────────────────────────────────
///
/// One KYC check row per attempt. A contributor can have multiple
/// rows over time (re-attempt after rejection, annual re-verification).
/// The "active" row is the most recent non-archived one — service
/// layer enforces a single in-flight row per user (no two pending
/// submissions at once).
///
/// Lifecycle:
///   pending → submitted → under_review → approved   (terminal)
///                                      → rejected   (terminal)
///                                      → hold       (contributor needs to provide more info; can resubmit)
model KycCheck {
  id            String @id @default(cuid())
  contributorId String

  /// 'pending' | 'submitted' | 'under_review' | 'approved' | 'rejected' | 'hold'
  status        String  @default("pending")

  /// JSON list of document refs the contributor uploaded:
  ///   [{ kind: 'id_card', name, url, mimeType, sizeBytes? }, ...]
  /// kind: 'id_card' | 'address_proof' | 'pan' | 'passport' | 'other'
  documents     Json?

  /// Risk score from automated screening (0-100; higher = riskier).
  /// Null when no automated screen has run yet.
  riskScore     Int?

  /// Reviewer who currently holds the row (under_review).
  assigneeId    String?
  assignedAt    DateTime?

  /// Set when the contributor submits the docs.
  submittedAt   DateTime?
  /// Set when reviewer reaches a terminal status.
  decidedAt     DateTime?
  decidedBy     String?
  /// Required for rejected + hold. Optional for approved.
  decisionReason String?

  /// When the row transitioned to 'hold' (cleared on resubmit).
  heldAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  contributor User  @relation("KycContributor", fields: [contributorId], references: [id], onDelete: Cascade)
  assignee    User? @relation("KycAssignee",    fields: [assigneeId],    references: [id], onDelete: SetNull)

  @@index([contributorId, status])
  @@index([status])
  @@index([assigneeId])
  @@index([contributorId, createdAt(sort: Desc)])
}

/// ─────────────────────────────────────────────────────────────────
/// M26 — Payment rail health
/// ─────────────────────────────────────────────────────────────────
///
/// One row per rail status transition. Most recent row per rail is
/// authoritative; older rows form an audit trail of state changes.
///
/// Status:
///   active   — rail healthy; withdrawals process normally
///   degraded — rail slow / partial outage; new withdrawals auto-hold;
///              admin can drain in-flight payouts
///   down     — rail fully down; same effect as degraded for new requests
model RailHealth {
  id        String @id @default(cuid())
  /// Rail identifier (e.g. 'razorpay_x'). Multiple rows per rail
  /// across time; most recent wins.
  rail      String
  /// 'active' | 'degraded' | 'down'
  status    String  @default("active")
  /// Operator-supplied reason for non-'active' states.
  reason    String?
  /// Who flipped the switch.
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rail, createdAt(sort: Desc)])
}
